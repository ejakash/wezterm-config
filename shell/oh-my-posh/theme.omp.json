{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }}{{ if .Root }} :: root{{ end }}",
  "palette": {
    "text": "#2c232e",
    "os_bg": "#ded5d0",
    "surface": "#ded5d0",
    "username_bg": "#e193a6",
    "path_bg": "#8eb1cf",
    "git_clean": "#b8d0c4",
    "git_dirty": "#b0a0c5",
    "git_ahead": "#9ec5b5",
    "git_behind": "#e6a389",
    "arrow_ok": "#cd4872",
    "arrow_err": "#a8201a",
    "muted": "#a59c9c",
    "lang_node": "#b8d0c4",
    "lang_python": "#d5ac75",
    "lang_dotnet": "#b0a0c5",
    "lang_go": "#8eb1cf",
    "lang_rust": "#e6a389",
    "lang_kube": "#8eb1cf"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "p:text",
          "background": "p:os_bg",
          "template": " {{ if .WSL }}{{ else }}{{ .Icon }}{{ end }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:username_bg",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:path_bg",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "hide_root_location": false,
            "folder_icon": "",
            "home_icon": ""
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:git_clean",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:git_dirty{{ end }}",
            "{{ if gt .Ahead 0 }}p:git_ahead{{ end }}",
            "{{ if gt .Behind 0 }}p:git_behind{{ end }}"
          ],
          "properties": {
            "branch_icon": " ",
            "cherry_pick_icon": " ",
            "commit_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "merge_icon": " ",
            "no_commits_icon": " ",
            "rebase_icon": " ",
            "revert_icon": " ",
            "tag_icon": " "
          },
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "transparent",
          "background": "transparent",
          "template": ""
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_node",
          "properties": {
            "fetch_package_manager": true,
            "display_mode": "context"
          },
          "template": "  {{ .Full }} "
        },
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_python",
          "properties": {
            "display_mode": "context",
            "fetch_virtual_env": true
          },
          "template": "  {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_dotnet",
          "properties": {
            "display_mode": "context"
          },
          "template": "  {{ .Full }} "
        },
        {
          "type": "go",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_go",
          "properties": {
            "display_mode": "context"
          },
          "template": "  {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_rust",
          "properties": {
            "display_mode": "context"
          },
          "template": "  {{ .Full }} "
        },
        {
          "type": "kubectl",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:lang_kube",
          "properties": {
            "display_mode": "context"
          },
          "template": " ﴱ {{ .Context }}{{ if .Namespace }}/{{ .Namespace }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:text",
          "background": "p:surface",
          "properties": {
            "threshold": 50,
            "style": "roundrock"
          },
          "template": "  {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:arrow_err{{ end }}"
          ],
          "foreground": "p:arrow_ok",
          "template": "❯ "
        }
      ]
    }
  ],
  "secondary_prompt": {
    "foreground": "p:muted",
    "template": "❯❯ "
  }
}
